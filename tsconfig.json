{
    "compilerOptions": {
      "target": "ES2021",
      "module": "ESNext",
      "moduleResolution": "bundler",
      "lib": ["ES2021", "DOM", "DOM.Iterable"],
      "strict": true,
      "experimentalDecorators": true,
      "useDefineForClassFields": false,
      "declaration": true,
      "sourceMap": true,
      "outDir": "./dist"
    },
    "include": ["src"]
}